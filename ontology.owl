                <owl:onProperty rdf:resource="https://w3id.org/ppon/bppo#description"/>
                <owl:hasValue xml:lang="en">The luminaire maintenance factor is the ratio of the luminaires luminous flux before and after cleaning. It is presented as a table of environmental conditions depending on the cleaning period of the luminaire in years. Classification of the environmental conditions based on CIE 97:2005:  VC Very clean, C Clean, N Normal, D Dirty.</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ppon/bppo#digitalFormat"/>
