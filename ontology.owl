    <!-- https://w3id.org/ppon/lppo#overallMf -->


    <owl:NamedIndividual rdf:about="https://w3id.org/ppon/lppo#overallMf">
        <bppo:description xml:lang="en">Overall MF required to adapt the variations of MF standards.  E.g., Japanese Maintenance Factor standard JIEG-001(2013) defines and uses “Ml”, “Md” instead of “LLMF”, “LSF”, “LMF”, “RSMF”. The Japanese MF Procedure is different from CIE 97:2005. Overall MF covers the difference.</bppo:description>
