    <!-- https://w3id.org/ppon/lppo#RatedChromaticityCoordinateValues -->


    <owl:Class rdf:about="https://w3id.org/ppon/lppo#RatedChromaticityCoordinateValues">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ppon/bppo#Property"/>
