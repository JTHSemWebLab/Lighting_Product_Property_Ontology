        <bppo:digitalFormat>(1E0, mm)</bppo:digitalFormat>
        <bppo:hasGUID>2F38RxmOf3ow0715JRf5OO</bppo:hasGUID>
        <bppo:hasName xml:lang="en">overall radius</bppo:hasName>
