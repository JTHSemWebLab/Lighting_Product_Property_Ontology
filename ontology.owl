    <!-- https://w3id.org/ppon/lppo#OverallMf -->


    <owl:Class rdf:about="https://w3id.org/ppon/lppo#OverallMf">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ppon/bppo#Property"/>
