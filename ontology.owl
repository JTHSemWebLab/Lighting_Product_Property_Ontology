    <!-- https://w3id.org/ppon/lppo#PhotometricCentrePositionZDirection -->


    <owl:Class rdf:about="https://w3id.org/ppon/lppo#PhotometricCentrePositionZDirection">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ppon/bppo#Property"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ppon/bppo#memberOf"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/ppon/lppo#PhotometricProperties"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ppon/bppo#description"/>
                <owl:hasValue xml:lang="en">Z position of the point used as origin for photometric measurements and calculations in relation to the middle of the bounding box. Positive values are aligned with the gamma angle 180° (up). Negative values are aligned with the gamma angle 0° (down).  If the light centre point is at the bottom side, then this value is the negative half of the height. See also EN 13032-4:2015.</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ppon/bppo#digitalFormat"/>
