            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ppon/bppo#description"/>
                <owl:hasValue xml:lang="en">Chromaticity coordinates ratio of each of a set of 3 tristimulus values to their sum according ISO 11664-1:2007. As the sum of the 3 chromaticity coordinates is equal to 1, two of them are sufficient to define a chromaticity. In the CIE standard colorimetric systems, the chromaticity coordinates are represented by the symbols x, y, z and x10, y10, z10.</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ppon/bppo#digitalFormat"/>
                <owl:hasValue>(1E-2, n.a.)</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ppon/bppo#hasGUID"/>
                <owl:hasValue>2VsGUEC0v62AXkp0i8pFrI</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ppon/bppo#hasName"/>
                <owl:hasValue xml:lang="en">rated chromaticity coordinate values</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ppon/lppo#hasID"/>
                <owl:hasValue>04-0032</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:example>x:0.46 y:0.41</skos:example>
    </owl:Class>
    


