    <!-- https://w3id.org/ppon/lppo#PhotobiologyClass -->


    <owl:Class rdf:about="https://w3id.org/ppon/lppo#PhotobiologyClass">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ppon/bppo#Property"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ppon/bppo#memberOf"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/ppon/lppo#PhotometricProperties"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ppon/lppo#valueSet"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/ppon/lppo#PhotobiologyClassValueSet"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ppon/bppo#description"/>
                <owl:hasValue xml:lang="en">The required measurement methods and the calculation methodology are set in the harmonized standard IEC 62471:2009 / CIE S009:2006 „Photobiological safety of lamps and lamp systems“. The standard divides the sources of incoherent optical radiation into four groups: in the Exempt Group (no photobiological risk) and the Risk Groups 1 to 3 with increasing hazard potential.</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ppon/bppo#digitalFormat"/>
                <owl:hasValue>(1E0, n.a.)</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ppon/bppo#hasGUID"/>
                <owl:hasValue>1PL17P9t53oexZksoRkx7Y</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ppon/bppo#hasName"/>
                <owl:hasValue xml:lang="en">photobiology class</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ppon/lppo#hasID"/>
                <owl:hasValue>04-0037</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


