        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ppon/bppo#description"/>
                <owl:hasValue xml:lang="en">Overall MF required to adapt the variations of MF standards.  E.g., Japanese Maintenance Factor standard JIEG-001(2013) defines and uses “Ml”, “Md” instead of “LLMF”, “LSF”, “LMF”, “RSMF”. The Japanese MF Procedure is different from CIE 97:2005. Overall MF covers the difference.</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ppon/bppo#digitalFormat"/>
                <owl:hasValue>(1E-2)</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ppon/bppo#hasGUID"/>
                <owl:hasValue>0$H_zVMtjA3vm1ce$LVc1D</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ppon/bppo#hasName"/>
                <owl:hasValue xml:lang="en">overall MF</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ppon/lppo#hasID"/>
                <owl:hasValue>08-0036</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ppon/lppo#symbol"/>
                <owl:hasValue>MF</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


