    </owl:NamedIndividual>
    


    <!-- https://w3id.org/ppon/lppo#photobiologyClass -->


    <owl:NamedIndividual rdf:about="https://w3id.org/ppon/lppo#photobiologyClass">
        <bppo:description xml:lang="en">The required measurement methods and the calculation methodology are set in the harmonized standard IEC 62471:2009 / CIE S009:2006 „Photobiological safety of lamps and lamp systems“. The standard divides the sources of incoherent optical radiation into four groups: in the Exempt Group (no photobiological risk) and the Risk Groups 1 to 3 with increasing hazard potential.</bppo:description>
        <bppo:digitalFormat>(1E0, n.a.)</bppo:digitalFormat>
        <bppo:hasGUID>1PL17P9t53oexZksoRkx7Y</bppo:hasGUID>
        <bppo:hasName xml:lang="en">photobiology class</bppo:hasName>
        <hasID>04-0037</hasID>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/ppon/lppo#photometricBeamShape -->


    <owl:NamedIndividual rdf:about="https://w3id.org/ppon/lppo#photometricBeamShape">
        <bppo:description xml:lang="en">Description of photometric Beam typical shape.</bppo:description>
        <bppo:hasGUID>0wVs5XlEPE5gBsG3nTILKR</bppo:hasGUID>
        <bppo:hasName xml:lang="en">photometric beam shape</bppo:hasName>
        <hasID>04-0014</hasID>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/ppon/lppo#photometricCentrePositionXDirection -->


    <owl:NamedIndividual rdf:about="https://w3id.org/ppon/lppo#photometricCentrePositionXDirection">
        <bppo:description xml:lang="en">X position of the point used as origin for photometric measurements and calculations in relation to the middle of the bounding box. Positive values are aligned with the C0 level. Negative values are aligned with the C180 level. See EN 13032-4:2015.</bppo:description>
        <bppo:digitalFormat>(1E0, mm)</bppo:digitalFormat>
        <bppo:hasGUID>0FYKiM4lT7dAD13KWzXvsG</bppo:hasGUID>
        <bppo:hasName xml:lang="en">photometric centre position x direction</bppo:hasName>
        <hasID>04-0002</hasID>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/ppon/lppo#photometricCentrePositionYDirection -->


    <owl:NamedIndividual rdf:about="https://w3id.org/ppon/lppo#photometricCentrePositionYDirection">
        <bppo:description xml:lang="en">Y position of the point used as origin for photometric measurements and calculations in relation to the middle of the bounding box. Positive values are aligned with the C90 level. Negative values are aligned with the C270 level. See EN 13032-4:2015.</bppo:description>
        <bppo:digitalFormat>(1E0, mm)</bppo:digitalFormat>
        <bppo:hasGUID>3HorBzYr10DBaLrbgxq2fS</bppo:hasGUID>
        <bppo:hasName xml:lang="en">photometric centre position y direction</bppo:hasName>
        <hasID>04-0003</hasID>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/ppon/lppo#photometricCentrePositionZDirection -->


    <owl:NamedIndividual rdf:about="https://w3id.org/ppon/lppo#photometricCentrePositionZDirection">
        <bppo:description xml:lang="en">Z position of the point used as origin for photometric measurements and calculations in relation to the middle of the bounding box. Positive values are aligned with the gamma angle 180° (up). Negative values are aligned with the gamma angle 0° (down).  If the light centre point is at the bottom side, then this value is the negative half of the height. See also EN 13032-4:2015.</bppo:description>
        <bppo:digitalFormat>(1E0, mm)</bppo:digitalFormat>
        <bppo:hasGUID>2MDJxTVzv57ALNnXX1bC1W</bppo:hasGUID>
        <bppo:hasName xml:lang="en">photometric centre position z direction</bppo:hasName>
        <hasID>04-0004</hasID>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/ppon/lppo#photometricClassDin5040 -->


    <owl:NamedIndividual rdf:about="https://w3id.org/ppon/lppo#photometricClassDin5040">
        <bppo:description xml:lang="en">German standard with photometric classification.  The contributions to the effective luminous flux are then rated and summed up per room segment.</bppo:description>
        <bppo:hasGUID>3weB85rrjDBOfsW2DojyA8</bppo:hasGUID>
        <bppo:hasName xml:lang="en">photometric class DIN5040</bppo:hasName>
        <hasID>04-0038</hasID>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/ppon/lppo#photometricClassUte -->


    <owl:NamedIndividual rdf:about="https://w3id.org/ppon/lppo#photometricClassUte">
        <bppo:description xml:lang="en">French standard with photometric classification. The standard NF (UTE) C71-121 (1995) in France, &quot;Méthode simplifiée de prédétermination des éclairements dans les espaces clos et classification correspondante des luminaires&quot;.</bppo:description>
        <bppo:hasGUID>3bKRB3yaT3s8fMSl_u6Kyb</bppo:hasGUID>
        <bppo:hasName xml:lang="en">photometric class UTE</bppo:hasName>
        <hasID>04-0040</hasID>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/ppon/lppo#photometricCode -->


    <owl:NamedIndividual rdf:about="https://w3id.org/ppon/lppo#photometricCode">
        <bppo:description xml:lang="en">A code consists out of CRI, CCT, initial colour variation (MacAdam ellipse steps), colour variation through life (MacAdam ellipse steps) and lumen maintenance value (Lx).</bppo:description>
        <bppo:hasGUID>2BFsFYpCbFKfkbtjAMxZOc</bppo:hasGUID>
        <bppo:hasName xml:lang="en">photometric code</bppo:hasName>
        <hasID>04-0017</hasID>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/ppon/lppo#photometry -->


