            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ppon/bppo#hasGUID"/>
                <owl:hasValue>03XhO08LHDWvZXteTHjOi9</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ppon/bppo#hasName"/>
                <owl:hasValue xml:lang="en">acoustic absorption table</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ppon/lppo#hasID"/>
                <owl:hasValue>08-0030</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <skos:example>1.6 at 500Hz</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/ppon/lppo#ActivePower -->


    <owl:Class rdf:about="https://w3id.org/ppon/lppo#ActivePower">
        <rdfs:subClassOf rdf:resource="https://w3id.org/ppon/bppo#Property"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ppon/bppo#memberOf"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/ppon/lppo#ElectricalProperties"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/ppon/bppo#description"/>
                <owl:hasValue xml:lang="en">Consumption of the power corresponding to the dim level of the luminaire. It is presented as a table of power (W) related to the luminous flux emitted (lm) or the percentage of dimming (%).</owl:hasValue>
