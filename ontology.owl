    <!-- https://w3id.org/ppon/lppo#EmergencyOperationTypeValueSet -->


    <rdfs:Datatype rdf:about="https://w3id.org/ppon/lppo#EmergencyOperationTypeValueSet">
        <owl:equivalentClass>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</rdf:first>
                        <rdf:rest>
