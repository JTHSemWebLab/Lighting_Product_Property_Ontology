                <owl:onProperty rdf:resource="https://w3id.org/ppon/bppo#description"/>
                <owl:hasValue xml:lang="en">X position of the point used as origin for photometric measurements and calculations in relation to the middle of the bounding box. Positive values are aligned with the C0 level. Negative values are aligned with the C180 level. See EN 13032-4:2015.</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
