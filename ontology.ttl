                    <https://w3id.org/ppon/bppo#hasGUID> "19BQiuhJj8qgDgvk6nbxxB" ;
                    <https://w3id.org/ppon/bppo#hasName> "abrupt failure value"@en ;
                    :hasID "08-0015" ;
                    :symbol "AFV" .


