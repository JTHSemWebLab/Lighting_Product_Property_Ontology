                             owl:hasValue "0$H_zVMtjA3vm1ce$LVc1D"
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty <https://w3id.org/ppon/bppo#hasName> ;
                             owl:hasValue "overall MF"@en
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasID ;
                             owl:hasValue "08-0036"
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :symbol ;
                             owl:hasValue "MF"
                           ] .


