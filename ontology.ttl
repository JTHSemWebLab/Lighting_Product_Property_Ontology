             rdfs:subClassOf <https://w3id.org/ppon/bppo#Property> ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty <https://w3id.org/ppon/bppo#memberOf> ;
                               owl:someValuesFrom :ElectricalProperties
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty <https://w3id.org/ppon/bppo#description> ;
                               owl:hasValue "Ratio of the amount of the active power to the apparent power at 100% load. See also IEC 80000-6:2008."@en
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty <https://w3id.org/ppon/bppo#digitalFormat> ;
                               owl:hasValue "(1E0, n.a.)"
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty <https://w3id.org/ppon/bppo#hasGUID> ;
                               owl:hasValue "3LBrQkLDDFheBOxrGk8Zr_"
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty <https://w3id.org/ppon/bppo#hasName> ;
                               owl:hasValue "power factor"@en
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :hasID ;
                               owl:hasValue "02-0003"
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :symbol ;
                               owl:hasValue "cos φ"
                             ] .


###  https://w3id.org/ppon/lppo#PresenceDetectionArea
:PresenceDetectionArea rdf:type owl:Class ;
                       rdfs:subClassOf <https://w3id.org/ppon/bppo#Property> ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty <https://w3id.org/ppon/bppo#memberOf> ;
                                         owl:someValuesFrom :SensingDeviceProperties
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty <https://w3id.org/ppon/bppo#description> ;
                                         owl:hasValue "Detection area for minor movement for the standard mounting height. For round area: the angular range from 1° to 360° and radius [m]. For rectangular area: L x W [m]"@en
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty <https://w3id.org/ppon/bppo#digitalFormat> ;
                                         owl:hasValue "(1E0, ° 1E0, m)"
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty <https://w3id.org/ppon/bppo#hasGUID> ;
                                         owl:hasValue "3E7MzAVgHDlBQIdGhHFHL1"
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty <https://w3id.org/ppon/bppo#hasName> ;
                                         owl:hasValue "presence detection area"@en
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :hasID ;
                                         owl:hasValue "05-0010"
                                       ] .


