                                     owl:onProperty <https://w3id.org/ppon/bppo#description> ;
                                     owl:hasValue "The required measurement methods and the calculation methodology are set in the harmonized standard IEC 62471:2009 / CIE S009:2006 „Photobiological safety of lamps and lamp systems“. The standard divides the sources of incoherent optical radiation into four groups: in the Exempt Group (no photobiological risk) and the Risk Groups 1 to 3 with increasing hazard potential."@en
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty <https://w3id.org/ppon/bppo#digitalFormat> ;
                                     owl:hasValue "(1E0, n.a.)"
