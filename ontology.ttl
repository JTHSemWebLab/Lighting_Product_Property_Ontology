###  https://w3id.org/ppon/lppo#RatedChromaticityCoordinateValues
:RatedChromaticityCoordinateValues rdf:type owl:Class ;
                                   rdfs:subClassOf <https://w3id.org/ppon/bppo#Property> ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty <https://w3id.org/ppon/bppo#memberOf> ;
                                                     owl:someValuesFrom :PhotometricProperties
                                                   ] ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty <https://w3id.org/ppon/bppo#description> ;
                                                     owl:hasValue "Chromaticity coordinates ratio of each of a set of 3 tristimulus values to their sum according ISO 11664-1:2007. As the sum of the 3 chromaticity coordinates is equal to 1, two of them are sufficient to define a chromaticity. In the CIE standard colorimetric systems, the chromaticity coordinates are represented by the symbols x, y, z and x10, y10, z10."@en
                                                   ] ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty <https://w3id.org/ppon/bppo#digitalFormat> ;
                                                     owl:hasValue "(1E-2, n.a.)"
                                                   ] ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty <https://w3id.org/ppon/bppo#hasGUID> ;
                                                     owl:hasValue "2VsGUEC0v62AXkp0i8pFrI"
                                                   ] ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty <https://w3id.org/ppon/bppo#hasName> ;
                                                     owl:hasValue "rated chromaticity coordinate values"@en
                                                   ] ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty :hasID ;
                                                     owl:hasValue "04-0032"
                                                   ] ;
                                   <http://www.w3.org/2004/02/skos/core#example> "x:0.46 y:0.41" .


###  https://w3id.org/ppon/lppo#RatedInputPower
:RatedInputPower rdf:type owl:Class ;
                 rdfs:subClassOf <https://w3id.org/ppon/bppo#Property> ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty <https://w3id.org/ppon/bppo#memberOf> ;
                                   owl:someValuesFrom :ElectricalProperties
                                 ] ,
                                 [ rdf:type owl:Restriction ;
