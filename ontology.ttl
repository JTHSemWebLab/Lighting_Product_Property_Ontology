                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty <https://w3id.org/ppon/bppo#description> ;
                                      owl:hasValue "Abrupt failure value AFV percentile of LED modules failing to operate at median useful life, Lx. AFV depended significantly on the control gear failure."@en
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty <https://w3id.org/ppon/bppo#digitalFormat> ;
                                      owl:hasValue "(1E0, %)"
