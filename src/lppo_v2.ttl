###  https://w3id.org/ppon/lppo#photometricCentrePositionXDirection
:photometricCentrePositionXDirection rdf:type owl:DatatypeProperty ;
    rdfs:domain :PhotometricProperties ;
    bppo:hasGUID "0FYKiM4lT7dAD13KWzXvsG"^^xsd:string ;
    bppo:hasName "photometric centre position x direction"@en ;
    bppo:description "X position of the point used as origin for photometric measurements and calculations in relation to the middle of the bounding box. Positive values are aligned with the C0 level. Negative values are aligned with the C180 level. See EN 13032-4:2015."@en ;
    bppo:digitalFormat "(1E0, mm)"^^xsd:string ;
    :hasID "04-0002"^^xsd:string .

