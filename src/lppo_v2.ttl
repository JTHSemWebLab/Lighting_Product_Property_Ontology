###  https://w3id.org/ppon/lppo#ratedChromaticityCoordinateValues
:ratedChromaticityCoordinateValues rdf:type owl:DatatypeProperty ;
    rdfs:domain :PhotometricProperties ;
    bppo:hasGUID "2VsGUEC0v62AXkp0i8pFrI"^^xsd:string ;
    bppo:hasName "rated chromaticity coordinate values"@en ;
    bppo:description "Chromaticity coordinates ratio of each of a set of 3 tristimulus values to their sum according ISO 11664-1:2007. As the sum of the 3 chromaticity coordinates is equal to 1, two of them are sufficient to define a chromaticity. In the CIE standard colorimetric systems, the chromaticity coordinates are represented by the symbols x, y, z and x10, y10, z10."@en ;
    bppo:digitalFormat "(1E-2, n.a.)"^^xsd:string ;
    :hasID "04-0032"^^xsd:string ;
    skos:example "x:0.46 y:0.41" .

